# ─────────────────────────────────────────────────────────────
# Frank's Retirement Home — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# All variables below are REQUIRED unless marked (optional).
# See docs/SETUP.md for step-by-step instructions.
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL via Supabase) ────────────────────────
#
# FRH uses Supabase PostgreSQL accessed through Prisma ORM.
# Two connection strings are required — one pooled, one direct.
#
# Find both strings in:
#   Supabase Dashboard → Project → Settings → Database → Connection string
#
# ── DATABASE_URL (pooled — runtime) ──────────────────────────
# Used by the Next.js application at runtime (all API routes).
# Use the "Transaction" mode pooler URL (Supavisor, port 6543).
#
# Format:
#   postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
#
# In Supabase dashboard: Settings → Database → Connection string → Transaction
# For optimal performance with serverless, append: ?connection_limit=5&pool_timeout=10
DATABASE_URL="postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres"

# ── DIRECT_URL (direct — migrations only) ────────────────────
# Used exclusively by Prisma CLI for migrations and schema operations:
#   prisma migrate dev / prisma migrate deploy / prisma migrate reset
#
# Use the direct (non-pooled) connection string (port 5432).
# This bypasses Supavisor so Prisma can issue DDL statements reliably.
#
# Format:
#   postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# In Supabase dashboard: Settings → Database → Connection string → Session
# Note: port 5432 = session mode (direct). Port 6543 = transaction mode (pooled).
DIRECT_URL="postgresql://postgres.PROJECT-REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Admin Authentication ──────────────────────────────────────

# Password required to access the /admin dashboard.
ADMIN_PASSWORD="change-me"

# HMAC secret for signing the admin session cookie.
# Must be at least 16 characters. Generate with:
#   openssl rand -base64 48
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# ── Discord OAuth ─────────────────────────────────────────────

# Discord OAuth Application (https://discord.com/developers/applications)
# Create an application, go to OAuth2, copy Client ID and Client Secret.
# Required for Discord-based captain/admin authentication.
# These must also be set in Vercel Environment Variables for production.
DISCORD_CLIENT_ID="YOUR_DISCORD_CLIENT_ID"
DISCORD_CLIENT_SECRET="YOUR_DISCORD_CLIENT_SECRET"

# Discord Server (Guild) ID
# Enable Developer Mode in Discord Settings > Advanced, then right-click
# your server name > Copy Server ID.
DISCORD_GUILD_ID="YOUR_DISCORD_GUILD_ID"

# HMAC secret for signing the Discord session cookie (separate from admin secret).
# Must be at least 16 characters. Generate with:
#   openssl rand -base64 48
DISCORD_SESSION_SECRET="change-me-to-a-long-random-string"

# ── Discord Role IDs ──────────────────────────────────────────
# Server Settings > Roles > right-click role > Copy Role ID
# (Developer Mode must be enabled)

# Admin role — full dashboard + admin API access via Discord
DISCORD_ADMIN_ROLE_ID="YOUR_ADMIN_ROLE_ID"

# Captain roles (per-division) — one captain role per division
# Having either role means "is a captain" AND "belongs to this division"
DISCORD_HOSPICE_CAPTAIN_ROLE_ID="YOUR_HOSPICE_CAPTAIN_ROLE_ID"
DISCORD_REHABILITATION_CAPTAIN_ROLE_ID="YOUR_REHABILITATION_CAPTAIN_ROLE_ID"

# Player roles (per-division, comma-separated)
# These indicate active season players. Two skill-level roles per division.
# Hospice = Scooter + Wheelchair roles
# Rehabilitation = Walker + Canes roles
DISCORD_HOSPICE_PLAYER_ROLE_IDS="SCOOTER_ROLE_ID,WHEELCHAIR_ROLE_ID"
DISCORD_REHABILITATION_PLAYER_ROLE_IDS="WALKER_ROLE_ID,CANES_ROLE_ID"

# ── Discord Team Role Map ─────────────────────────────────────
# JSON mapping FRH Team.id -> Discord role ID for that team.
# Team IDs are deterministic (from prisma/seed.mjs).
# Populate Discord role IDs after creating team roles in your Discord server.
# Required for Discord OAuth captain authorization.
DISCORD_TEAM_ROLE_MAP_JSON='{
  "team-galactic-stingers":  "YOUR_GALACTIC_STINGERS_ROLE_ID",
  "team-caustic-crusaders":  "YOUR_CAUSTIC_CRUSADERS_ROLE_ID",
  "team-death-dealers":      "YOUR_DEATH_DEALERS_ROLE_ID",
  "team-wheezys-mafia":      "YOUR_WHEEZYS_MAFIA_ROLE_ID",
  "team-ruined-order":       "YOUR_RUINED_ORDER_ROLE_ID",
  "team-kappa-corp":         "YOUR_KAPPA_CORP_ROLE_ID",
  "team-exile-extinction":   "YOUR_EXILE_EXTINCTION_ROLE_ID",
  "team-valhalla-vikings":   "YOUR_VALHALLA_VIKINGS_ROLE_ID",
  "team-babas-kitchen":      "YOUR_BABAS_KITCHEN_ROLE_ID",
  "team-cyberpunk-otters":   "YOUR_CYBERPUNK_OTTERS_ROLE_ID"
}'

# ── OCR / AI ──────────────────────────────────────────────────

# (optional) Google Gemini API key for screenshot OCR extraction.
# Used by lib/gemini.js for captain screenshot uploads via /api/ocr/extract.
# Without this, screenshot extraction fails gracefully.
# Get a key at: https://aistudio.google.com
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# (optional) Gemini model for OCR extraction. Defaults to gemini-1.5-flash.
GEMINI_MODEL=

# ── ForgeLens OCR Worker ──────────────────────────────────────
# (optional) External OCR worker integration. When FORGELENS_URL is set,
# /api/forgelens/jobs dispatches extraction jobs to the worker, which
# posts results back to /api/forgelens/callback.
# See docs/forgelens-worker-architecture.md.
FORGELENS_URL=

# Bearer token sent to the ForgeLens worker when dispatching jobs.
FORGELENS_API_KEY=

# Shared HMAC-SHA256 secret used to verify X-ForgeLens-Signature on
# /api/forgelens/callback. REQUIRED in production if the worker is used:
# the callback rejects all requests (503) when this is unset, because
# without it forged OCR results could be injected.
# Generate with: openssl rand -hex 32
FORGELENS_HMAC_SECRET=

# Public base URL of this app (no trailing slash). Used to build the
# ForgeLens callback URL and absolute links (e.g. match share URLs).
# Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_ORIGIN=

# ── Discord Webhooks ─────────────────────────────────────────
# (optional) Outgoing Discord webhook URL for roster transaction notifications.
# Messages post to whichever Discord channel owns the configured webhook URL.
# Create in Discord server settings → Integrations → Webhooks.
DISCORD_TRANSACTIONS_WEBHOOK_URL=

# ── OAuth Callback URL ────────────────────────────────────────
# Base URL for OAuth redirects. Set to your deployment URL.
# Locally: http://localhost:3000
# Production: https://your-vercel-app.vercel.app
# The callback path is: /api/auth/discord/callback
# This URL must be added to Discord Developer Portal > OAuth2 > Redirects.
NEXTAUTH_URL="http://localhost:3000"

# ─── Sentry (error monitoring — production only) ─────────────────────────────
# SENTRY_DSN is required for error reporting. Get it from sentry.io.
# SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN are only needed at build time
# for source map uploads — the app works without them.
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Upstash Redis (distributed rate limiting — optional) ────────────────────
# Without these, rate limiting falls back to per-process in-memory.
# Get from console.upstash.com — use the REST API credentials.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
