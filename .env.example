# ─────────────────────────────────────────────────────────────
# Frank's Retirement Home — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# All variables below are REQUIRED unless marked (optional).
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL via Neon) ────────────────────────────

# Pooled connection URL — used at runtime by the application.
# Format: postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Direct (non-pooled) connection URL — used by Prisma for migrations
# (prisma migrate deploy / prisma migrate reset). Remove "-pooler" from the hostname.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# ── Admin Authentication ──────────────────────────────────────

# Password required to access the /admin dashboard.
ADMIN_PASSWORD="change-me"

# HMAC secret for signing the admin session cookie.
# Must be at least 16 characters. Generate with:
#   openssl rand -base64 48
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# (optional) Set to "true" to enforce cookie-based auth on all
# admin-mutating API routes. Defaults to "false" so the cookie
# path can be deployed and verified before being enforced.
# Once enabled, admins must log in at /admin before mutations
# (creating/deleting drafts, managing players/gods, etc.) succeed.
ADMIN_AUTH_REQUIRED="false"
