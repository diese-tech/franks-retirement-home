# PostgreSQL (Neon) — copy this file to .env.local and fill in your values
# Pooled URL (used at runtime by the app)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"
# Direct URL (used by Prisma migrations/db push — remove -pooler from the hostname)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"

# Admin dashboard password (used by /api/admin-auth)
ADMIN_PASSWORD="change-me"

# HMAC secret for the admin session cookie. Minimum 16 characters; required
# in production. Generate with: `openssl rand -base64 48`
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# Set to "true" to enforce cookie-based auth on admin-mutating API routes.
# Defaults to off so the cookie path can be deployed and verified before
# being switched on. Once flipped on, admins must log in at /admin before
# mutations succeed (creating/deleting drafts, managing players/gods,
# assembling teams, importing players).
ADMIN_AUTH_REQUIRED="false"
