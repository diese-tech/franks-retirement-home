generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Season {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  status      String    @default("upcoming") // upcoming | active | completed
  startsAt    DateTime?
  endsAt      DateTime?
  currentWeek Int       @default(1)
  createdAt   DateTime  @default(now())

  divisions Division[]
  matches   Match[]
}

model Division {
  id        String   @id @default(cuid())
  seasonId  String
  name      String   // "Hospice" | "Rehabilitation"
  tier      Int      // 1 = lower, 2 = higher (display/sorting only; not a pick gate)
  createdAt DateTime @default(now())

  season  Season  @relation(fields: [seasonId], references: [id])
  teams   Team[]
  matches Match[]

  @@unique([seasonId, name])
}

model Org {
  id           String   @id @default(cuid())
  name         String
  tag          String
  logoInitials String?
  accentColor  String?
  createdAt    DateTime @default(now())

  teams Team[]
}

model Team {
  id              String   @id @default(cuid())
  divisionId      String
  orgId           String?
  name            String
  tag             String
  captainPlayerId String?
  createdAt       DateTime @default(now())

  division    Division    @relation(fields: [divisionId], references: [id])
  org         Org?        @relation(fields: [orgId], references: [id])
  members     TeamMember[]
  homeMatches Match[]     @relation("HomeTeam")
  awayMatches Match[]     @relation("AwayTeam")
}

model TeamMember {
  id        String    @id @default(cuid())
  teamId    String
  playerId  String
  role      String    // Solo | Jungle | Mid | Support | Carry | Fill
  isCaptain Boolean   @default(false)
  isSub     Boolean   @default(false)
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([teamId, playerId])
}

model Match {
  id                 String    @id @default(cuid())
  seasonId           String
  divisionId         String
  week               Int
  scheduledAt        DateTime?
  status             String    @default("scheduled") // scheduled | live | completed | postponed
  homeTeamId         String
  awayTeamId         String
  format             String    @default("BO1")        // BO1 | BO3 | BO5
  streamUrl          String?
  vodUrl             String?
  homeTeamCaptainKey String?   @unique
  awayTeamCaptainKey String?   @unique
  createdAt          DateTime  @default(now())

  season   Season   @relation(fields: [seasonId], references: [id])
  division Division @relation(fields: [divisionId], references: [id])
  homeTeam Team     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam Team     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  games    Game[]
}

model Game {
  id              String   @id @default(cuid())
  matchId         String
  gameNumber      Int      // 1-based within the match
  winnerTeamId    String?
  durationSeconds Int?
  createdAt       DateTime @default(now())

  match Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  draft Draft?

  @@unique([matchId, gameNumber])
}

model Player {
  id              String   @id @default(cuid())
  name            String
  role            String   // Solo, Jungle, Mid, Support, Carry, Fill
  discordUsername String?
  division        String?  // e.g. Hospice, Rehabilitation
  createdAt       DateTime @default(now())

  draftPicks      DraftPick[]
  teamMemberships TeamMember[]
}

model God {
  id        String   @id @default(cuid())
  name      String
  role      String   // Warrior, Assassin, Mage, Guardian, Hunter
  godClass  String   // Physical, Magical
  createdAt DateTime @default(now())

  draftPicks DraftPick[]
  draftBans  DraftBan[]
}

model Draft {
  id             String   @id @default(cuid())
  name           String   @default("Draft")
  status         String   @default("pending") // pending | lobby | banning | picking | complete
  captainAKey    String?  @unique
  captainBKey    String?  @unique
  adminKey       String?  @unique
  captainAReady  Boolean  @default(false)
  captainBReady  Boolean  @default(false)
  usedGodIds     Json     @default("[]")
  version        Int      @default(0)
  chatsVersion   Int      @default(0)
  // Nullable FK to Game. Null = standalone draft (scrims/testing). @unique = one draft per game at most.
  gameId         String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  picks DraftPick[]
  bans  DraftBan[]
  chats DraftChat[]
  game  Game?        @relation(fields: [gameId], references: [id])
}

model DraftPick {
  id        String   @id @default(cuid())
  draftId   String
  playerId  String
  team      String   // A or B
  godId     String?
  pickOrder Int      @default(0)
  createdAt DateTime @default(now())

  draft  Draft   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  god    God?    @relation(fields: [godId], references: [id], onDelete: SetNull)

  @@unique([draftId, playerId])
}

model DraftBan {
  id        String   @id @default(cuid())
  draftId   String
  godId     String
  team      String   // A or B — which team submitted the ban
  banOrder  Int      @default(0)
  createdAt DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  god   God   @relation(fields: [godId], references: [id], onDelete: Cascade)

  @@unique([draftId, godId])
}

model DraftChat {
  id         String   @id @default(cuid())
  draftId    String
  team       String   // A | B | admin | spectator
  senderName String
  message    String
  createdAt  DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}
