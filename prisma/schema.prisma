generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Player {
  id         String   @id @default(cuid())
  name      String
  role      String   // Solo, Jungle, Mid, Support, Carry
  createdAt DateTime @default(now())

  draftPicks DraftPick[]
}

model God {
  id        String   @id @default(cuid())
  name      String
  role      String   // Warrior, Assassin, Mage, Guardian, Hunter
  godClass  String   // Physical, Magical
  createdAt DateTime @default(now())

  draftPicks DraftPick[]
  draftBans  DraftBan[]
}

model Draft {
  id             String   @id @default(cuid())
  name           String   @default("Draft")
  status         String   @default("pending") // pending | lobby | banning | picking | complete | active (legacy)
  captainAKey    String?  @unique
  captainBKey    String?  @unique
  adminKey       String?  @unique
  captainAReady  Boolean  @default(false)
  captainBReady  Boolean  @default(false)
  version        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  picks DraftPick[]
  bans  DraftBan[]
  chats DraftChat[]
}

model DraftPick {
  id        String   @id @default(cuid())
  draftId   String
  playerId  String
  team      String   // A or B
  godId     String?
  pickOrder Int      @default(0)
  createdAt DateTime @default(now())

  draft  Draft   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  god    God?    @relation(fields: [godId], references: [id], onDelete: SetNull)

  @@unique([draftId, playerId])
}

model DraftBan {
  id        String   @id @default(cuid())
  draftId   String
  godId     String
  team      String   // A or B — which team submitted the ban
  banOrder  Int      @default(0)
  createdAt DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  god   God   @relation(fields: [godId], references: [id], onDelete: Cascade)

  @@unique([draftId, godId])
}

model DraftChat {
  id         String   @id @default(cuid())
  draftId    String
  team       String   // A | B | admin | spectator
  senderName String
  message    String
  createdAt  DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}
