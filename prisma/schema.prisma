generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Season {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  status      String    @default("upcoming") // upcoming | active | completed
  startsAt    DateTime?
  endsAt      DateTime?
  currentWeek Int       @default(1)
  createdAt   DateTime  @default(now())

  divisions      Division[]
  matches        Match[]
  playerDrafts   PlayerDraft[]
  rosterImports  RosterImport[]
  bulletinPosts  BulletinPost[]
  editorialCases EditorialCase[]
}

model Division {
  id        String   @id @default(cuid())
  seasonId  String
  name      String   // "Hospice" | "Rehabilitation"
  tier      Int      // 1 = lower, 2 = higher (display/sorting only; not a pick gate)
  createdAt DateTime @default(now())

  season         Season          @relation(fields: [seasonId], references: [id])
  teams          Team[]
  matches        Match[]
  playerDraft    PlayerDraft?
  bulletinPosts  BulletinPost[]
  editorialCases EditorialCase[]

  @@unique([seasonId, name])
}

model Org {
  id           String   @id @default(cuid())
  name         String
  tag          String
  logoInitials String?
  accentColor  String?
  createdAt    DateTime @default(now())

  teams Team[]
}

model Team {
  id              String   @id @default(cuid())
  divisionId      String
  orgId           String?
  name            String
  tag             String
  captainPlayerId String?
  createdAt       DateTime @default(now())

  division         Division          @relation(fields: [divisionId], references: [id])
  org              Org?              @relation(fields: [orgId], references: [id])
  members          TeamMember[]
  homeMatches      Match[]           @relation("HomeTeam")
  awayMatches      Match[]           @relation("AwayTeam")
  playerDraftPicks PlayerDraftPick[]
  statLines        StatLine[]
  bulletinPosts    BulletinPost[]
  editorialCases   EditorialCase[]
  bettingLinesA    BettingLine[]     @relation("BettingLineTeamA")
  bettingLinesB    BettingLine[]     @relation("BettingLineTeamB")
  selectedBets     Bet[]             @relation("BetSelectedTeam")
  changeRequests   ChangeRequest[]

  @@index([divisionId])
}

model TeamMember {
  id        String    @id @default(cuid())
  teamId    String
  playerId  String
  role      String    // Solo | Jungle | Mid | Support | Carry | Fill
  isCaptain Boolean   @default(false)
  isSub     Boolean   @default(false)
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])

  @@unique([teamId, playerId])
}

model Match {
  id                   String    @id @default(cuid())
  seasonId             String
  divisionId           String
  week                 Int
  defaultScheduledAt   DateTime? // Immutable original schedule anchor — eligibility window derives from this only
  scheduledAt          DateTime? // Currently approved play time — updated by approved reschedule requests
  status               String    @default("scheduled") // scheduled | live | completed | postponed
  homeTeamId           String
  awayTeamId           String
  format               String    @default("BO1")        // BO1 | BO3 | BO5
  streamUrl            String?
  vodUrl               String?
  homeTeamCaptainKey   String?   @unique
  awayTeamCaptainKey   String?   @unique
  createdAt            DateTime  @default(now())

  season              Season              @relation(fields: [seasonId], references: [id])
  division            Division            @relation(fields: [divisionId], references: [id])
  homeTeam            Team                @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam            Team                @relation("AwayTeam", fields: [awayTeamId], references: [id])
  games               Game[]
  submissions         MatchSubmission[]
  rescheduleRequests  RescheduleRequest[]
  bulletinPosts       BulletinPost[]
  editorialCases      EditorialCase[]
  bettingLines        BettingLine[]

  // One fixture per home/away pairing per week — guards against double-run
  // scheduling actions inserting duplicate matches.
  @@unique([seasonId, week, homeTeamId, awayTeamId])
  // Standings computation filters by division + completed status on every
  // cache miss; schedule pages filter by season + week.
  @@index([divisionId, status])
  @@index([seasonId, week])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model Game {
  id              String   @id @default(cuid())
  matchId         String
  gameNumber      Int      // 1-based within the match
  winnerTeamId    String?  // set when result is confirmed (or by admin override)
  durationSeconds Int?
  createdAt       DateTime @default(now())

  // ── Layer 1: live captain result flow ─────────────────────────────────────
  // Status machine: pending → reported → confirmed | disputed
  // Transitions:
  //   pending   → reported  : one captain POSTs a result
  //   reported  → confirmed : opposing captain PATCHes action=confirm
  //   reported  → disputed  : opposing captain PATCHes action=dispute
  //   disputed  → confirmed : admin PATCHes action=resolve (sets winnerTeamId)
  resultStatus          String?  // pending | reported | confirmed | disputed
  reportedWinnerTeamId  String?  // which team the reporting captain says won
  reportedByTeamId      String?  // which team submitted the report (home or away)
  confirmedByTeamId     String?  // which team confirmed the result
  resultReportedAt      DateTime?
  resultConfirmedAt     DateTime?
  resultDisputedAt      DateTime?

  match          Match             @relation(fields: [matchId], references: [id], onDelete: Cascade)
  draft          Draft?
  submissions    MatchSubmission[]
  statLines      StatLine[]
  ocrExtractions OcrExtraction[]

  @@unique([matchId, gameNumber])
}

// ─── PlayerDraft ─────────────────────────────────────────────────────────────

// Season-scoped snake draft of players to teams within a division.
// Status machine: pending → active → paused → complete
// Completion transaction upserts TeamMember rows from all PlayerDraftPick rows.
model PlayerDraft {
  id               String    @id @default(cuid())
  seasonId         String
  divisionId       String    @unique // one draft per division enforced here
  name             String    @default("Player Draft")
  status           String    @default("pending") // pending | active | paused | complete
  rounds           Int       @default(5)
  pickTimerSeconds Int       @default(120)        // 0 = no timer
  // Original approved pick order (teamId array). Immutable once draft starts — audit trail.
  baseOrder        Json      @default("[]")
  // Live order — admin applies bilateral slot-trade requests here.
  // Even round index uses currentOrder; odd uses reversed.
  currentOrder     Json      @default("[]")
  // 0-based index into buildPickSequence(currentOrder, rounds).
  currentPickIndex Int       @default(0)
  pickStartedAt    DateTime?
  adminKey         String?   @unique
  version          Int       @default(0)
  createdAt        DateTime  @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  updatedAt        DateTime  @updatedAt

  season   Season            @relation(fields: [seasonId], references: [id])
  division Division          @relation(fields: [divisionId], references: [id])
  picks    PlayerDraftPick[]

  @@unique([seasonId, divisionId])
}

model PlayerDraftPick {
  id            String   @id @default(cuid())
  playerDraftId String
  pickNumber    Int      // 1-based across the full snake sequence
  teamId        String
  playerId      String
  pickedAt      DateTime @default(now())

  playerDraft PlayerDraft @relation(fields: [playerDraftId], references: [id], onDelete: Cascade)
  team        Team        @relation(fields: [teamId], references: [id])
  player      Player      @relation(fields: [playerId], references: [id])

  @@unique([playerDraftId, playerId])   // a player can only be drafted once
  @@unique([playerDraftId, pickNumber]) // each pick slot is unique
}

// ─── Match Submissions ────────────────────────────────────────────────────────

model MatchSubmission {
  id                   String    @id @default(cuid())
  matchId              String
  gameId               String?
  submittedByPlayerId  String?   // captain who submitted; null if admin-created
  status               String    @default("pending") // pending | in_review | approved | rejected | superseded
  reportedWinnerTeamId String?
  notes                String?
  rejectionReason      String?
  reviewStartedAt      DateTime?
  reviewedAt           DateTime?
  reviewedByAdminId    String?   // opaque admin identifier — no User table in S9
  createdAt            DateTime  @default(now())

  match       Match                  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  game        Game?                  @relation(fields: [gameId], references: [id])
  attachments SubmissionAttachment[]
}

model SubmissionAttachment {
  id           String   @id @default(cuid())
  submissionId String
  kind         String   // screenshot | document
  url          String
  checksum     String?
  mimeType     String?
  byteSize     Int?
  uploadedAt   DateTime @default(now())

  submission MatchSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
}

// ─── Core Draft Engine ────────────────────────────────────────────────────────

model Player {
  id              String   @id @default(cuid())
  name            String
  role            String   // Solo, Jungle, Mid, Support, Carry, Fill
  discordUsername String?
  discordId       String?
  avatarUrl       String?
  claimedByUserId String?
  division        String?  // e.g. Hospice, Rehabilitation
  timezone        String?
  secondaryRoles  String[] @default([])
  createdAt       DateTime @default(now())

  draftPicks         DraftPick[]
  teamMemberships    TeamMember[]
  playerDraftPicks   PlayerDraftPick[]
  statLines          StatLine[]
  extractedStatLines ExtractedStatLine[]
  aliases            PlayerAlias[]
  claimedByUser      User?              @relation("ClaimedByUser", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  playerClaims       PlayerClaim[]
  bulletinPosts      BulletinPost[]
  editorialCases     EditorialCase[]
  wallet             Wallet?
}

model God {
  id        String   @id @default(cuid())
  name      String
  role      String   // Warrior, Assassin, Mage, Guardian, Hunter
  godClass  String   // Physical, Magical
  createdAt DateTime @default(now())

  draftPicks         DraftPick[]
  draftBans          DraftBan[]
  statLines          StatLine[]
  extractedStatLines ExtractedStatLine[]
}

model Draft {
  id             String   @id @default(cuid())
  name           String   @default("Draft")
  status         String   @default("pending") // pending | lobby | banning | picking | complete
  captainAKey    String?  @unique
  captainBKey    String?  @unique
  adminKey       String?  @unique
  captainAReady  Boolean  @default(false)
  captainBReady  Boolean  @default(false)
  usedGodIds     Json     @default("[]")
  version        Int      @default(0)
  chatsVersion   Int      @default(0)
  // Nullable FK to Game. Null = standalone draft (scrims/testing). @unique = one draft per game at most.
  gameId         String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  picks DraftPick[]
  bans  DraftBan[]
  chats DraftChat[]
  game  Game?        @relation(fields: [gameId], references: [id])
}

// PRE-SEASON ONLY: playerId is nullable to support team-level picks during the
// draft and post-draft Lineup Confirmation. Existing picks with playerId set are
// unaffected. @@unique([draftId, playerId]) allows multiple null playerId rows
// in Postgres (nulls are not considered equal in unique indexes).
model DraftPick {
  id        String   @id @default(cuid())
  draftId   String
  playerId  String?
  team      String   // A or B
  godId     String?
  pickOrder Int      @default(0)
  createdAt DateTime @default(now())

  draft  Draft   @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)
  god    God?    @relation(fields: [godId], references: [id], onDelete: SetNull)

  @@unique([draftId, playerId])
}

model DraftBan {
  id        String   @id @default(cuid())
  draftId   String
  godId     String
  team      String   // A or B — which team submitted the ban
  banOrder  Int      @default(0)
  createdAt DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  god   God   @relation(fields: [godId], references: [id], onDelete: Cascade)

  @@unique([draftId, godId])
}

model DraftChat {
  id         String   @id @default(cuid())
  draftId    String
  team       String   // A | B | admin | spectator
  senderName String
  message    String
  createdAt  DateTime @default(now())

  draft Draft @relation(fields: [draftId], references: [id], onDelete: Cascade)
}

// ─── Stat Lines ───────────────────────────────────────────────────────────────

// Per-player per-game statistics entered manually by admin after a match.
// One row per player per game. godId is nullable for games before Lineup Confirmation.
model StatLine {
  id        String   @id @default(cuid())
  gameId    String
  playerId  String
  teamId    String
  godId     String?  // which god this player used
  role      String?  // role played in this specific game (may differ from player.role)
  kills           Int      @default(0)
  deaths          Int      @default(0)
  assists         Int      @default(0)
  damage          Int      @default(0) // player damage dealt
  damageMitigated Int      @default(0)
  healing         Int      @default(0) // self + ally healing combined
  structureDamage Int      @default(0)
  gold            Int      @default(0)
  notes           String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id])
  team   Team   @relation(fields: [teamId], references: [id])
  god    God?   @relation(fields: [godId], references: [id], onDelete: SetNull)

  @@unique([gameId, playerId]) // one stat line per player per game
  // Player-profile and team stat aggregation query by player/team first.
  @@index([playerId])
  @@index([teamId])
}

// ─── Reschedule Requests ─────────────────────────────────────────────────────

// Governance workflow for match rescheduling.
// Status machine: pending → acknowledged | disputed → approved | denied
// Only admin approval updates Match.scheduledAt.
// Match.defaultScheduledAt (eligibility window anchor) is NEVER changed.
model RescheduleRequest {
  id                    String    @id @default(cuid())
  matchId               String
  proposedScheduledAt   DateTime
  // Which captain side submitted: "home" | "away"
  requestedByCaptainSide String
  // "pending" | "acknowledged" | "disputed" | "approved" | "denied"
  status                String    @default("pending")
  evidenceText          String?
  // Opposing captain response text (optional note alongside ack/dispute)
  opposingCaptainNote   String?
  // Admin decision fields
  adminNote             String?
  adminId               String?   // opaque admin identifier — no User table in S9
  decidedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([status])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

// Append-only log of admin actions. Never modified after insert.
// payload is a JSON object with action-specific context.
model AuditLog {
  id        String   @id @default(cuid())
  entity    String   // "Match" | "PlayerDraft" | "MatchSubmission" | "StatLine" | etc.
  entityId  String
  action    String   // "created" | "approved" | "rejected" | "status_changed" | "pick_recorded" | etc.
  adminId   String?  // opaque identifier — no User table in S9
  payload   Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

model ChangeRequest {
  id               String    @id @default(cuid())
  type             String    // ROSTER_ADD | ROSTER_REMOVE
  teamId           String
  requestedById    String    // discordId of captain
  requestedByName  String
  payload          Json      // { playerId, playerName, role, reason }
  status           String    @default("pending") // pending | approved | rejected
  reviewedById     String?   // discordId or 'admin'
  reviewedByName   String?
  reviewNote       String?
  createdAt        DateTime  @default(now())
  reviewedAt       DateTime?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([teamId])
}

// ─── ForgeLens OCR Pipeline ───────────────────────────────────────────────────

// One row per screenshot submitted for OCR. Tracks job lifecycle.
// Status: pending → processing → completed | needs_review | failed
model OcrExtraction {
  id                String    @id @default(cuid())
  submissionId      String?   // optional link to the MatchSubmission that triggered this
  gameId            String?   // which game's stats are being extracted
  status            String    @default("pending") // pending | processing | completed | needs_review | failed
  attachmentUrl     String    // the screenshot URL sent to ForgeLens
  attachmentChecksum String?
  mimeType          String?
  confidence        Float?    // returned by ForgeLens (0.0–1.0)
  parserVersion     String?
  rawModelOutput    String?   // raw Gemini text (for audit / debugging)
  warnings          Json      @default("[]") // array of { field, ign, reason }
  errorMessage      String?
  requestedAt       DateTime  @default(now())
  completedAt       DateTime?

  game        Game?              @relation(fields: [gameId], references: [id])
  rows        ExtractedStatLine[]
}

// One row per player-row in the ForgeLens callback `rows` array.
// Admin reviews and approves/rejects before these become canonical StatLine rows.
model ExtractedStatLine {
  id             String  @id @default(cuid())
  extractionId   String
  status         String  @default("pending") // pending | approved | rejected
  // Raw values from ForgeLens (stored as extracted, not yet resolved)
  ignRaw         String  // ign as parsed from the screenshot
  teamRaw        String? // "home" | "away" as parsed
  roleRaw        String?
  godRaw         String?
  kills          Int     @default(0)
  deaths         Int     @default(0)
  assists        Int     @default(0)
  damageDealt    Int     @default(0)
  damageMitigated Int    @default(0)
  healing        Int     @default(0)
  goldEarned     Int     @default(0)
  structureDamage Int    @default(0)
  confidence     Float?  // per-row confidence if provided
  // Admin-resolved references (null until admin confirms identity)
  resolvedPlayerId String?
  resolvedGodId    String?
  rejectionReason  String?

  extraction OcrExtraction @relation(fields: [extractionId], references: [id], onDelete: Cascade)
  player     Player?       @relation(fields: [resolvedPlayerId], references: [id], onDelete: SetNull)
  god        God?          @relation(fields: [resolvedGodId], references: [id], onDelete: SetNull)
}

// IGN aliases — maps raw player name variants to a canonical Player row.
// Created by admin when a ForgeLens extraction fails to auto-resolve a name.
model PlayerAlias {
  id        String   @id @default(cuid())
  playerId  String
  alias     String   // raw name variant (case-sensitive as ForgeLens returns it)
  source    String   @default("admin") // "admin" | "forgelens" | "import"
  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([alias]) // one canonical player per alias string
}

// ─── Homepage Content ─────────────────────────────────────────────────────────
//
// Stores admin-edited editorial content for the public homepage.
// Two logical rows exist at most:
//   status="draft"     — work-in-progress, visible only to admins
//   status="published" — live content rendered on the public page
//
// When no "published" row exists the public page falls back to the hardcoded
// JS defaults in lib/homepageDefaults.js — zero regression on fresh deploys.
//
// JSON field shapes are documented in lib/homepageDefaults.js.
model HomepageContent {
  id     String @id @default(cuid())
  status String @default("draft") // "draft" | "published"

  // ── Editable sections (JSON arrays / objects) ──────────────────────────────
  ticker       Json @default("[]")  // TickerItem[]
  headlines    Json @default("[]")  // HeadlineItem[]
  bulletin     Json @default("[]")  // BulletinItem[]
  fraudWatch   Json @default("[]")  // FraudItem[]
  motw         Json @default("{}")  // MotwData
  rivalries    Json @default("[]")  // RivalryItem[]
  knowsBall    Json @default("[]")  // KnowsBallItem[]
  washedReports Json @default("[]") // WashedItem[]
  socialCards  Json @default("[]")  // SocialCardItem[]

  // ── Scalar overrides ───────────────────────────────────────────────────────
  discordInviteUrl String @default("https://discord.gg/HPAZmHmBpD")
  washedPct        Int    @default(88)

  // ── Section visibility toggles ─────────────────────────────────────────────
  showTicker        Boolean @default(true)
  showHeadlines     Boolean @default(true)
  showBulletin      Boolean @default(true)
  showFraudWatch    Boolean @default(true)
  showMotw          Boolean @default(true)
  showRivalries     Boolean @default(true)
  showKnowsBall     Boolean @default(true)
  showWashedReports Boolean @default(true)
  showSocialCards   Boolean @default(true)

  // ── Audit fields ───────────────────────────────────────────────────────────
  savedAt        DateTime  @default(now())
  publishedAt    DateTime?
  savedByAdminId String?

  @@unique([status]) // only one draft and one published row at a time
  @@index([status])
}

// ─── Identity & Profile Claims ────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  discordId String   @unique
  username  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  playerProfiles Player[]      @relation("ClaimedByUser")
  claimedPlayers PlayerClaim[] @relation("ClaimRequester")
  reviewedClaims PlayerClaim[] @relation("ClaimReviewer")
  rosterImports  RosterImport[]
  wallet         Wallet?
}

model PlayerClaim {
  id           String    @id @default(cuid())
  userId       String
  playerId     String
  status       String    @default("pending") // pending | approved | denied
  requestedAt  DateTime  @default(now())
  reviewedAt   DateTime?
  reviewedById String?
  note         String?

  user       User    @relation("ClaimRequester", fields: [userId], references: [id])
  player     Player  @relation(fields: [playerId], references: [id])
  reviewedBy User?   @relation("ClaimReviewer", fields: [reviewedById], references: [id])

  @@index([userId])
  @@index([playerId])
  @@index([status])
}

// ─── CSV Import Staging ───────────────────────────────────────────────────────

model RosterImport {
  id            String    @id @default(cuid())
  seasonId      String?
  status        String    @default("staged") // staged | imported | failed
  rawFilename   String?
  columnMapping Json      @default("{}")
  createdById   String?
  createdAt     DateTime  @default(now())
  importedAt    DateTime?

  season    Season?          @relation(fields: [seasonId], references: [id])
  createdBy User?            @relation(fields: [createdById], references: [id])
  rows      RosterImportRow[]
}

model RosterImportRow {
  id             String   @id @default(cuid())
  importId       String
  rowIndex       Int
  rawData        Json
  normalizedData Json?
  status         String   @default("pending") // pending | valid | invalid | imported | skipped
  errors         Json?
  createdAt      DateTime @default(now())

  import RosterImport @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@index([importId])
  @@index([status])
}

// ─── Bulletin Board ───────────────────────────────────────────────────────────

model BulletinPost {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  type              String    // announcement | match_hype | player_spotlight | team_roast | weekly_recap
  status            String    @default("draft") // draft | published | archived
  body              String
  excerpt           String?
  pinned            Boolean   @default(false)
  displayOrder      Int?
  relatedPlayerId   String?
  relatedTeamId     String?
  relatedMatchId    String?
  relatedDivisionId String?
  relatedSeasonId   String?
  createdById       String?
  updatedById       String?
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  relatedPlayer   Player?   @relation(fields: [relatedPlayerId], references: [id], onDelete: SetNull)
  relatedTeam     Team?     @relation(fields: [relatedTeamId], references: [id], onDelete: SetNull)
  relatedMatch    Match?    @relation(fields: [relatedMatchId], references: [id], onDelete: SetNull)
  relatedDivision Division? @relation(fields: [relatedDivisionId], references: [id], onDelete: SetNull)
  relatedSeason   Season?   @relation(fields: [relatedSeasonId], references: [id], onDelete: SetNull)
  reactions       BulletinReaction[]
  comments        BulletinComment[]

  @@index([status])
  @@index([type])
  @@index([publishedAt])
}

// ─── Bulletin Community: Reactions & Comments ─────────────────────────────────
//
// Discord-authenticated community engagement on published bulletin posts.
// Identity is the Discord ID (opaque string) — no User row is required, matching
// the stateless cookie session model. authorName is a display snapshot.

model BulletinReaction {
  id        String   @id @default(cuid())
  postId    String
  discordId String   // reacting user's Discord ID
  emoji     String   // beer | fire | skull | goat | clown
  createdAt DateTime @default(now())

  post BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, discordId, emoji]) // one of each emoji per user per post
  @@index([postId])
}

model BulletinComment {
  id         String   @id @default(cuid())
  postId     String
  discordId  String   // commenter's Discord ID (for ownership checks)
  authorName String   // display snapshot of username at comment time
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  post BulletinPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

// ─── Weekly Superlatives ──────────────────────────────────────────────────────
//
// Beer-league community awards (e.g. "Beer League MVP", "Most Washed").
// Admins create and edit `active` superlatives directly on the page; players
// can suggest new ones, which land as `suggested` for admin review. Purely
// editorial/cosmetic — never touches real standings, so competitive integrity
// is preserved.

model Superlative {
  id           String   @id @default(cuid())
  title        String
  description  String?
  nominee      String?  // free-text nominee (admin-set)
  status       String   @default("active") // active | suggested | archived
  weekLabel    String?
  displayOrder Int?
  createdById  String?  // admin username who created/approved
  suggestedBy  String?  // player username who suggested (when status=suggested)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
}

// ─── Homepage Section Config ──────────────────────────────────────────────────

model HomepageSectionConfig {
  id           String   @id @default(cuid())
  sectionKey   String   @unique
  title        String?
  subtitle     String?
  statusText   String?
  visible      Boolean  @default(true)
  displayOrder Int?
  metadata     Json?
  updatedById  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Fraud Watch / Washed Reports Editorial Cases ─────────────────────────────

model EditorialCase {
  id                String    @id @default(cuid())
  type              String    // fraud_watch | washed_report
  status            String    @default("draft") // draft | published | archived
  severity          Int?
  title             String
  charge            String?
  body              String?
  relatedPlayerId   String?
  relatedTeamId     String?
  relatedMatchId    String?
  relatedDivisionId String?
  relatedSeasonId   String?
  signalSource      Json?
  createdById       String?
  updatedById       String?
  publishedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  relatedPlayer   Player?   @relation(fields: [relatedPlayerId], references: [id], onDelete: SetNull)
  relatedTeam     Team?     @relation(fields: [relatedTeamId], references: [id], onDelete: SetNull)
  relatedMatch    Match?    @relation(fields: [relatedMatchId], references: [id], onDelete: SetNull)
  relatedDivision Division? @relation(fields: [relatedDivisionId], references: [id], onDelete: SetNull)
  relatedSeason   Season?   @relation(fields: [relatedSeasonId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([status])
}

// ─── Fantasy Points / Team Odds Economy ──────────────────────────────────────

model Wallet {
  id        String    @id @default(cuid())
  userId    String    @unique
  playerId  String?   @unique
  balance   Int       @default(0)
  status    String    @default("unopened") // unopened | active | suspended
  openedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user         User                @relation(fields: [userId], references: [id])
  player       Player?             @relation(fields: [playerId], references: [id], onDelete: SetNull)
  transactions WalletTransaction[]
  bets         Bet[]
}

model WalletTransaction {
  id           String   @id @default(cuid())
  walletId     String
  type         String   // starter_grant | bet_stake | bet_payout | admin_adjustment | fine | bonus | void_refund
  amount       Int
  balanceAfter Int
  reason       String?
  createdById  String?
  createdAt    DateTime @default(now())

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
}

model BettingLine {
  id            String    @id @default(cuid())
  matchId       String
  status        String    @default("open") // open | locked | settled | void
  teamAId       String
  teamAOdds     Int
  teamBId       String
  teamBOdds     Int
  closesAt      DateTime?
  createdById   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  settledAt     DateTime?
  winningTeamId String?   // teamAId or teamBId, recorded at settlement (bet resolution)

  match  Match  @relation(fields: [matchId], references: [id])
  teamA  Team   @relation("BettingLineTeamA", fields: [teamAId], references: [id])
  teamB  Team   @relation("BettingLineTeamB", fields: [teamBId], references: [id])
  bets   Bet[]

  @@index([matchId])
}

model Bet {
  id              String    @id @default(cuid())
  walletId        String
  lineId          String
  selectedTeamId  String
  stake           Int
  potentialPayout Int
  status          String    @default("pending") // pending | won | lost | void
  createdAt       DateTime  @default(now())
  settledAt       DateTime?

  wallet       Wallet      @relation(fields: [walletId], references: [id])
  line         BettingLine @relation(fields: [lineId], references: [id])
  selectedTeam Team        @relation("BetSelectedTeam", fields: [selectedTeamId], references: [id])

  @@index([walletId])
  @@index([lineId])
}
